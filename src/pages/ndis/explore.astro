export const prerender = false;
---
import BaseHead from '../../components/BaseHead.astro';

export const prerender = false;

const SITE_TITLE = 'NDIS Provider Register | On The Record';
const SITE_DESCRIPTION = 'Browse compliance actions, banning orders, and enforcement history for NDIS providers.';
---
<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
    <style>
      body { background: #0a0a0a; color: #e8e8e8; font-family: 'Courier New', monospace; margin: 0; }

      .header-bar {
        background: #1a0000; border-bottom: 3px solid #cc0000;
        padding: 0.9rem 2rem; display: flex; align-items: center; gap: 1rem;
      }
      .header-bar h1 { font-size: 1.3rem; font-weight: 900; text-transform: uppercase; letter-spacing: 0.2em; color: #cc0000; margin: 0; }
      .tagline { color: #555; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.1em; }
      .back-link { margin-left: auto; color: #444; font-size: 0.7rem; letter-spacing: 0.1em; text-decoration: none; text-transform: uppercase; }
      .back-link:hover { color: #cc0000; }

      .filters { background: #0f0f0f; border-bottom: 1px solid #222; padding: 1rem 2rem; display: flex; flex-direction: column; gap: 0.75rem; }
      .filter-row { display: flex; align-items: center; gap: 0.5rem; flex-wrap: wrap; }
      .filter-label { color: #444; font-size: 0.65rem; text-transform: uppercase; letter-spacing: 0.15em; min-width: 70px; }

      .pill { background: #111; border: 1px solid #2a2a2a; color: #555; font-family: 'Courier New', monospace; font-size: 0.7rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; padding: 0.3rem 0.75rem; cursor: pointer; transition: all 0.12s; white-space: nowrap; }
      .pill:hover { border-color: #555; color: #aaa; }
      .pill.active { background: #cc0000; border-color: #cc0000; color: #fff; }

      .pill[data-risk="critical"].active { background: #ff2020; border-color: #ff2020; }
      .pill[data-risk="high"].active     { background: #ff8c00; border-color: #ff8c00; color: #000; }
      .pill[data-risk="medium"].active   { background: #ffd600; border-color: #ffd600; color: #000; }
      .pill[data-risk="low"].active      { background: #22c55e; border-color: #22c55e; color: #000; }

      .scroll-row { display: flex; gap: 0.4rem; overflow-x: auto; padding-bottom: 2px; scrollbar-width: none; flex-wrap: wrap; }
      .scroll-row::-webkit-scrollbar { display: none; }

      .sort-row { display: flex; gap: 0; border: 1px solid #222; overflow: hidden; }
      .sort-pill { background: #0a0a0a; border: none; border-right: 1px solid #222; color: #444; font-family: 'Courier New', monospace; font-size: 0.68rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; padding: 0.3rem 0.9rem; cursor: pointer; transition: all 0.12s; }
      .sort-pill:last-child { border-right: none; }
      .sort-pill:hover { color: #aaa; background: #111; }
      .sort-pill.active { background: #111; color: #e8e8e8; border-bottom: 2px solid #cc0000; }

      .search-input { background: #111; border: 1px solid #2a2a2a; color: #e8e8e8; padding: 0.3rem 0.75rem; font-family: 'Courier New', monospace; font-size: 0.8rem; min-width: 220px; }
      .search-input:focus { outline: 1px solid #cc0000; border-color: #cc0000; }
      .search-input::placeholder { color: #333; }

      .count-bar {
        padding: 0.6rem 2rem; font-size: 0.72rem; letter-spacing: 0.08em;
        border-bottom: 1px solid #151515; display: flex; gap: 1.5rem; flex-wrap: wrap; align-items: center;
      }
      .count-critical { color: #ff2020; }
      .count-high     { color: #ff8c00; }
      .count-medium   { color: #ffd600; }
      .count-low      { color: #22c55e; }
      .count-total    { color: #444; margin-left: auto; }

      .grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
        gap: 1.2rem; padding: 1.5rem 2rem;
        max-width: 1600px; margin: 0 auto;
        transition: opacity 0.2s;
      }
      .grid.fading { opacity: 0; }

      .provider-card {
        background: #0d0d0d; border: 1px solid #1e1e1e;
        cursor: pointer; text-decoration: none; color: inherit;
        display: block; transition: border-color 0.15s, box-shadow 0.15s;
        overflow: hidden; padding: 1rem;
      }
      .provider-card:hover {
        border-color: #cc0000;
        box-shadow: 0 0 18px rgba(204,0,0,0.25), 0 0 4px rgba(204,0,0,0.1);
      }

      .provider-name { font-size: 0.9rem; font-weight: 700; color: #e8e8e8; text-transform: uppercase; letter-spacing: 0.03em; line-height: 1.2; margin-bottom: 0.3rem; }
      .provider-meta { font-size: 0.62rem; color: #555; text-transform: uppercase; letter-spacing: 0.04em; margin-bottom: 0.5rem; }

      .risk-badge {
        display: inline-block; font-size: 0.65rem; font-weight: 900; letter-spacing: 0.08em;
        text-transform: uppercase; padding: 0.2rem 0.5rem; color: #000; margin-bottom: 0.5rem;
      }
      .risk-badge.critical { background: #ff2020; color: #fff; animation: badge-pulse 1.8s ease-in-out infinite; }
      .risk-badge.high     { background: #ff8c00; }
      .risk-badge.medium   { background: #ffd600; }
      .risk-badge.low      { background: #22c55e; }
      .risk-badge.unknown  { background: #333; color: #888; }

      @keyframes badge-pulse {
        0%, 100% { box-shadow: 0 0 4px rgba(255,32,32,0.6); }
        50%       { box-shadow: 0 0 14px rgba(255,32,32,1), 0 0 28px rgba(255,32,32,0.4); }
      }

      .action-count { font-size: 0.7rem; color: #555; margin-top: 0.3rem; }
      .perm-ban { font-size: 0.65rem; font-weight: 900; color: #cc0000; letter-spacing: 0.1em; margin-top: 0.3rem; }

      .empty-state { text-align: center; padding: 4rem; color: #444; grid-column: 1/-1; }
      .loading-state { text-align: center; padding: 4rem; color: #444; }

      footer { border-top: 1px solid #151515; padding: 1.5rem 2rem; text-align: center; color: #2e2e2e; font-size: 0.7rem; }
    </style>
  </head>
  <body>
    <div class="header-bar">
      <div>
        <h1>NDIS Provider Register</h1>
        <div class="tagline">Compliance actions, banning orders, and enforcement history</div>
      </div>
      <a href="/ndis/" class="back-link">← Home</a>
    </div>

    <div class="filters">
      <!-- Risk -->
      <div class="filter-row">
        <span class="filter-label">Risk</span>
        <button class="pill active" data-filter="risk" data-value="">ALL</button>
        <button class="pill" data-filter="risk" data-value="critical" data-risk="critical">CRITICAL</button>
        <button class="pill" data-filter="risk" data-value="high"     data-risk="high">HIGH</button>
        <button class="pill" data-filter="risk" data-value="medium"   data-risk="medium">MEDIUM</button>
        <button class="pill" data-filter="risk" data-value="low"      data-risk="low">LOW</button>
      </div>

      <!-- Action type -->
      <div class="filter-row">
        <span class="filter-label">Action</span>
        <div class="scroll-row">
          <button class="pill active" data-filter="action" data-value="">ALL</button>
          <button class="pill" data-filter="action" data-value="banning_order">BANNED</button>
          <button class="pill" data-filter="action" data-value="revocation">REVOKED</button>
          <button class="pill" data-filter="action" data-value="suspension">SUSPENDED</button>
          <button class="pill" data-filter="action" data-value="compliance_notice">COMPLIANCE NOTICE</button>
          <button class="pill" data-filter="action" data-value="enforceable_undertaking">UNDERTAKING</button>
        </div>
      </div>

      <!-- State -->
      <div class="filter-row">
        <span class="filter-label">State</span>
        <div class="scroll-row">
          <button class="pill active" data-filter="state" data-value="">ALL</button>
          <button class="pill" data-filter="state" data-value="NSW">NSW</button>
          <button class="pill" data-filter="state" data-value="VIC">VIC</button>
          <button class="pill" data-filter="state" data-value="QLD">QLD</button>
          <button class="pill" data-filter="state" data-value="SA">SA</button>
          <button class="pill" data-filter="state" data-value="WA">WA</button>
          <button class="pill" data-filter="state" data-value="TAS">TAS</button>
          <button class="pill" data-filter="state" data-value="ACT">ACT</button>
          <button class="pill" data-filter="state" data-value="NT">NT</button>
        </div>
      </div>

      <!-- Sort + Search -->
      <div class="filter-row" style="gap:1rem;flex-wrap:wrap;">
        <div style="display:flex;align-items:center;gap:0.5rem;">
          <span class="filter-label">Sort</span>
          <div class="sort-row">
            <button class="sort-pill active" data-sort="risk">HIGHEST RISK</button>
            <button class="sort-pill" data-sort="actions">MOST ACTIONS</button>
            <button class="sort-pill" data-sort="name">NAME</button>
          </div>
        </div>
        <input type="text" class="search-input" id="filter-search" placeholder="Search provider name or ABN…" />
      </div>
    </div>

    <div class="count-bar" id="count-bar">
      <span style="color:#333;">Loading…</span>
    </div>

    <div class="grid" id="provider-grid">
      <div class="loading-state">Loading provider register…</div>
    </div>

    <footer>Data sourced from NDIS Quality and Safeguards Commission compliance register &middot; Australian Business Register</footer>

    <script>
      import { playBeep, playSwipe, playAlert, playError } from '../../scripts/sounds';

      let allProviders: any[] = [];
      let currentFilters = { risk: '', action: '', state: '', q: '', sort: 'risk' };

      document.querySelectorAll('[data-filter]').forEach(btn => {
        btn.addEventListener('click', () => {
          const filter = (btn as HTMLElement).dataset.filter!;
          const value  = (btn as HTMLElement).dataset.value!;
          (currentFilters as any)[filter] = value;
          document.querySelectorAll(`[data-filter="${filter}"]`).forEach(b => b.classList.toggle('active', b === btn));
          playSwipe();
          applyFilters();
        });
      });

      document.querySelectorAll('[data-sort]').forEach(btn => {
        btn.addEventListener('click', () => {
          currentFilters.sort = (btn as HTMLElement).dataset.sort!;
          document.querySelectorAll('[data-sort]').forEach(b => b.classList.toggle('active', b === btn));
          playSwipe();
          applyFilters();
        });
      });

      let searchDebounce: ReturnType<typeof setTimeout>;
      document.getElementById('filter-search')!.addEventListener('input', e => {
        currentFilters.q = (e.target as HTMLInputElement).value;
        clearTimeout(searchDebounce);
        searchDebounce = setTimeout(applyFilters, 280);
      });

      async function loadAll() {
        try {
          // Load up to 500 providers (multiple pages if needed)
          const res = await fetch('/api/v1/ndis/providers/index.json?page=1');
          const data = await res.json();
          allProviders = data.providers || [];

          // If there are more pages, fetch them
          const total = data.total || 0;
          const pageSize = data.pageSize || 50;
          const pages = Math.ceil(total / pageSize);
          if (pages > 1) {
            const extras = await Promise.all(
              Array.from({ length: pages - 1 }, (_, i) =>
                fetch(`/api/v1/ndis/providers/index.json?page=${i + 2}`).then(r => r.json())
              )
            );
            for (const d of extras) allProviders = allProviders.concat(d.providers || []);
          }

          applyFilters();
          playAlert();
        } catch {
          document.getElementById('provider-grid')!.innerHTML = '<div class="empty-state">Failed to load data.</div>';
          playError();
        }
      }

      function applyFilters() {
        let list = allProviders.slice();
        const { risk, action, state, q, sort } = currentFilters;

        if (risk)   list = list.filter(p => (p.risk_label || 'unknown').toLowerCase() === risk);
        if (state)  list = list.filter(p => (p.state || '').toUpperCase() === state);
        if (action) list = list.filter(p => p._latestAction === action);  // enriched below
        if (q) {
          const lq = q.toLowerCase();
          list = list.filter(p =>
            (p.legal_name || '').toLowerCase().includes(lq) ||
            (p.trading_name || '').toLowerCase().includes(lq) ||
            (p.abn || '').includes(lq)
          );
        }

        list.sort((a, b) => {
          if (sort === 'risk')    return (b.risk_score || 0) - (a.risk_score || 0);
          if (sort === 'actions') return (b.action_count || 0) - (a.action_count || 0);
          if (sort === 'name')    return (a.legal_name || '').localeCompare(b.legal_name || '');
          return 0;
        });

        updateCountBar(list);
        renderGrid(list);
      }

      function updateCountBar(list: any[]) {
        const counts = { critical: 0, high: 0, medium: 0, low: 0 };
        list.forEach(p => {
          const r = (p.risk_label || 'low').toLowerCase() as keyof typeof counts;
          if (r in counts) counts[r]++;
        });
        const bar = document.getElementById('count-bar')!;
        bar.innerHTML = [
          counts.critical ? `<span class="count-critical">&#9670; ${counts.critical} CRITICAL</span>` : '',
          counts.high     ? `<span class="count-high">&#9670; ${counts.high} HIGH</span>` : '',
          counts.medium   ? `<span class="count-medium">&#9670; ${counts.medium} MEDIUM</span>` : '',
          counts.low      ? `<span class="count-low">&#9670; ${counts.low} LOW</span>` : '',
          `<span class="count-total">${list.length} ON RECORD</span>`,
        ].filter(Boolean).join('');
      }

      function actionLabel(type: string): string {
        const labels: Record<string, string> = {
          banning_order: 'Banning Order',
          revocation: 'Revocation',
          suspension: 'Suspension',
          enforceable_undertaking: 'Enforceable Undertaking',
          compliance_notice: 'Compliance Notice',
        };
        return labels[type] || type.replace(/_/g, ' ');
      }

      function renderGrid(providers: any[]) {
        const grid = document.getElementById('provider-grid')!;
        grid.classList.add('fading');
        setTimeout(() => {
          if (providers.length === 0) {
            grid.innerHTML = '<div class="empty-state">No providers match your filters.</div>';
          } else {
            grid.innerHTML = providers.map(p => {
              const rl = (p.risk_label || 'unknown').toLowerCase();
              const location = [p.suburb, p.state].filter(Boolean).join(', ');
              const isPermanentlyBanned = false; // enriched from actions

              return `
                <a class="provider-card" href="/ndis/providers/${p.id}">
                  <span class="risk-badge ${rl}">${rl.toUpperCase()}</span>
                  <div class="provider-name">${p.legal_name || 'Unknown'}</div>
                  ${p.abn ? `<div class="provider-meta">ABN ${p.abn}</div>` : ''}
                  ${location ? `<div class="provider-meta">${location}</div>` : ''}
                  <div class="action-count">${p.action_count || 0} COMPLIANCE ACTION${(p.action_count || 0) !== 1 ? 'S' : ''}</div>
                </a>`;
            }).join('');

            grid.querySelectorAll('.provider-card').forEach(card => {
              card.addEventListener('click', () => playBeep());
            });
          }
          grid.classList.remove('fading');
        }, 180);
      }

      loadAll();
    </script>
  </body>
</html>
