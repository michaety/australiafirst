---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			.hero {
				padding: 3rem 0;
				text-align: center;
			}
			.hero h1 {
				font-size: 3rem;
				margin-bottom: 1rem;
				color: #2c5282;
			}
			.hero p {
				font-size: 1.3rem;
				margin-bottom: 2rem;
				color: #4a5568;
			}
			.cta-button {
				display: inline-block;
				padding: 1rem 2rem;
				background: #4299e1;
				color: white;
				text-decoration: none;
				border-radius: 8px;
				font-size: 1.2rem;
				font-weight: bold;
				transition: background 0.3s;
			}
			.cta-button:hover {
				background: #2c5282;
			}
			.features {
				display: grid;
				grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
				gap: 2rem;
				margin: 3rem 0;
			}
			.feature {
				padding: 1.5rem;
				border: 1px solid #e2e8f0;
				border-radius: 8px;
				background: white;
			}
			.feature h3 {
				color: #2c5282;
				margin-bottom: 0.5rem;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="hero">
				<h1>Policy Alignment Index</h1>
				<p>Evidence-based politician profiles from voting records</p>
				<a href="/demo" class="cta-button">View Demo →</a>
			</div>

			<div class="features">
				<div class="feature">
					<h3>📊 Evidence-First</h3>
					<p>Every score links directly to the votes and divisions used in calculation.</p>
				</div>
				<div class="feature">
					<h3>🔍 Audit-Friendly</h3>
					<p>Raw upstream data stored in R2 with SHA256 hashes for reproducibility.</p>
				</div>
				<div class="feature">
					<h3>📈 Category Scores</h3>
					<p>Politicians scored across policy categories like Economic Resilience and Integrity & Transparency.</p>
				</div>
				<div class="feature">
					<h3>🎯 Coverage Metrics</h3>
					<p>Transparency about data completeness with coverage indicators.</p>
				</div>
			</div>

			<section style="margin: 3rem 0; padding: 2rem; background: #f7fafc; border-radius: 8px;">
				<h2 style="color: #2c5282;">System Architecture</h2>
				<ul style="line-height: 1.8;">
					<li><strong>Data Sources:</strong> OpenAustralia API, TheyVoteForYou</li>
					<li><strong>Database:</strong> Cloudflare D1 with 14 tables</li>
					<li><strong>Storage:</strong> KV for caching, R2 for audit trail</li>
					<li><strong>API:</strong> Stable JSON contracts at /api/v1/*</li>
					<li><strong>ETL:</strong> Automated daily sync with versioned scoring</li>
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>
