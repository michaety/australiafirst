---
import BaseHead from '../components/BaseHead.astro';

const SITE_TITLE = 'On The Record | Politician Accountability';
const SITE_DESCRIPTION = 'A public accountability register for Australian federal politicians. Documented votes, donations, promises, and foreign ties — all sourced from public records.';
---
<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
    <style>
      body { background: #0a0a0a; color: #e8e8e8; font-family: 'Courier New', monospace; }
      .header-bar {
        background: #1a0000;
        border-bottom: 3px solid #cc0000;
        padding: 1rem 2rem;
        display: flex;
        align-items: center;
        gap: 1rem;
      }
      .header-bar h1 {
        font-size: 1.4rem;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: 0.2em;
        color: #cc0000;
        margin: 0;
      }
      .tagline {
        color: #888;
        font-size: 0.8rem;
        text-transform: uppercase;
        letter-spacing: 0.1em;
      }
      .filters {
        background: #111;
        border-bottom: 1px solid #333;
        padding: 1rem 2rem;
        display: flex;
        gap: 1rem;
        align-items: center;
        flex-wrap: wrap;
      }
      .filters label {
        color: #888;
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.1em;
      }
      .filters select, .filters input {
        background: #1a1a1a;
        border: 1px solid #444;
        color: #e8e8e8;
        padding: 0.4rem 0.8rem;
        font-family: inherit;
        font-size: 0.85rem;
        cursor: pointer;
      }
      .filters select:focus, .filters input:focus {
        outline: 1px solid #cc0000;
        border-color: #cc0000;
      }
      .results-bar {
        padding: 0.75rem 2rem;
        font-size: 0.8rem;
        color: #666;
        border-bottom: 1px solid #1a1a1a;
      }
      .grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
        gap: 1.5rem;
        padding: 2rem;
        max-width: 1600px;
        margin: 0 auto;
      }
      .politician-card {
        background: #111;
        border: 1px solid #2a2a2a;
        cursor: pointer;
        transition: border-color 0.15s, transform 0.15s;
        text-decoration: none;
        color: inherit;
        display: block;
      }
      .politician-card:hover {
        border-color: #cc0000;
        transform: translateY(-2px);
      }
      .photo-container {
        position: relative;
        width: 100%;
        aspect-ratio: 3/4;
        overflow: hidden;
        background: #1a1a1a;
      }
      .photo-container img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        filter: grayscale(30%) contrast(1.1);
        display: block;
      }
      .photo-placeholder {
        width: 100%;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, #1a1a1a, #0f0f0f);
        font-size: 3rem;
        color: #333;
      }
      .photo-overlay {
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        padding: 0.5rem;
        background: linear-gradient(transparent, rgba(0,0,0,0.9));
      }
      .chamber-badge {
        display: inline-block;
        font-size: 0.6rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        padding: 0.15rem 0.4rem;
        border: 1px solid;
      }
      .chamber-badge.senate { color: #ff9900; border-color: #ff9900; }
      .chamber-badge.representatives { color: #00aaff; border-color: #00aaff; }
      .card-info {
        padding: 0.75rem;
      }
      .politician-name {
        font-size: 0.9rem;
        font-weight: 700;
        color: #e8e8e8;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        line-height: 1.3;
        margin-bottom: 0.25rem;
      }
      .party-pill {
        display: inline-block;
        font-size: 0.65rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        padding: 0.15rem 0.4rem;
        background: #1a1a1a;
        border: 1px solid #333;
        color: #aaa;
        margin-bottom: 0.25rem;
      }
      .electorate {
        font-size: 0.7rem;
        color: #666;
        text-transform: uppercase;
        letter-spacing: 0.05em;
      }
      .loading { text-align: center; padding: 4rem; color: #666; }
      .empty-state { text-align: center; padding: 4rem; color: #666; grid-column: 1/-1; }
      footer { border-top: 1px solid #1a1a1a; padding: 2rem; text-align: center; color: #444; font-size: 0.75rem; margin-top: 2rem; }
    </style>
  </head>
  <body>
    <div class="header-bar">
      <div>
        <h1>On The Record</h1>
        <div class="tagline">Federal Politician Accountability Register</div>
      </div>
    </div>

    <div class="filters">
      <div>
        <label for="filter-chamber">Chamber</label><br>
        <select id="filter-chamber">
          <option value="">All Chambers</option>
          <option value="representatives">House of Representatives</option>
          <option value="senate">Senate</option>
        </select>
      </div>
      <div>
        <label for="filter-party">Party</label><br>
        <select id="filter-party">
          <option value="">All Parties</option>
          <option value="ALP">Labor</option>
          <option value="LP">Liberal</option>
          <option value="NP">Nationals</option>
          <option value="GRN">Greens</option>
          <option value="PHON">One Nation</option>
          <option value="IND">Independent</option>
        </select>
      </div>
      <div>
        <label for="filter-search">Search</label><br>
        <input type="text" id="filter-search" placeholder="Name or electorate..." />
      </div>
      <div>
        <label for="filter-sort">Sort</label><br>
        <select id="filter-sort">
          <option value="name">Name</option>
          <option value="donors">Most Donors</option>
          <option value="actions">Most Actions</option>
          <option value="controversial">Most Controversial</option>
          <option value="risk">Highest Risk</option>
        </select>
      </div>
    </div>

    <div class="results-bar" id="results-count">Loading...</div>

    <div class="grid" id="politician-grid">
      <div class="loading">Loading accountability register...</div>
    </div>

    <footer>
      All data sourced from public records. APH, AEC, and Hansard.
    </footer>

    <script>
      let currentFilters = { chamber: '', party: '', q: '', sort: 'name' };

      async function loadPoliticians() {
        try {
          const params = new URLSearchParams();
          if (currentFilters.chamber) params.set('chamber', currentFilters.chamber);
          if (currentFilters.party) params.set('party', currentFilters.party);
          if (currentFilters.q) params.set('q', currentFilters.q);
          if (currentFilters.sort) params.set('sort', currentFilters.sort);

          const res = await fetch(`/api/v1/politicians.json?${params}`);
          const data = await res.json();
          renderGrid(data.politicians || []);
        } catch (e) {
          document.getElementById('politician-grid').innerHTML =
            '<div class="empty-state">Failed to load data. Please try again.</div>';
        }
      }

      function renderGrid(politicians) {
        const grid = document.getElementById('politician-grid');
        const count = document.getElementById('results-count');
        count.textContent = `${politicians.length} politician${politicians.length !== 1 ? 's' : ''} on record`;

        if (politicians.length === 0) {
          grid.innerHTML = '<div class="empty-state">No politicians match your filters.</div>';
          return;
        }

        grid.innerHTML = politicians.map(p => {
          const initials = p.name.split(' ').map(n => n[0]).join('').slice(0, 2);
          const photoHtml = p.photoUrl
            ? `<img src="${p.photoUrl}" alt="${p.name}" loading="lazy" style="width:100%;height:100%;object-fit:cover;object-position:top;filter:grayscale(30%) contrast(1.1);" onerror="this.style.display='none';this.nextElementSibling.style.display='flex'">`
            : '';
          const chamberClass = p.chamber === 'senate' ? 'senate' : 'representatives';
          const chamberLabel = p.chamber === 'senate' ? 'SEN' : 'REP';

          return `
            <a class="politician-card" href="/politicians/${p.id}">
              <div class="photo-container">
                ${photoHtml}
                <div class="photo-placeholder" ${p.photoUrl ? 'style="display:none"' : ''}>${initials}</div>
                <div class="photo-overlay">
                  <span class="chamber-badge ${chamberClass}">${chamberLabel}</span>
                  ${p.riskScore > 0 ? `<span style="position:absolute;top:6px;right:6px;padding:2px 6px;border-radius:3px;font-size:9px;font-weight:900;letter-spacing:1px;text-transform:uppercase;color:#000;background:${p.riskLabel === 'critical' ? '#ff2020' : p.riskLabel === 'high' ? '#ff8c00' : p.riskLabel === 'medium' ? '#ffd600' : '#22c55e'};">${p.riskLabel}</span>` : ''}
                </div>
              </div>
              <div class="card-info">
                <div class="politician-name">${p.name}</div>
                ${p.party ? `<div class="party-pill">${p.party}</div>` : ''}
                ${p.electorate ? `<div class="electorate">${p.electorate}</div>` : ''}
              </div>
            </a>
          `;
        }).join('');
      }

      let debounceTimer;
      function applyFilters() {
        clearTimeout(debounceTimer);
        debounceTimer = setTimeout(loadPoliticians, 300);
      }

      document.getElementById('filter-chamber').addEventListener('change', e => {
        currentFilters.chamber = e.target.value;
        applyFilters();
      });
      document.getElementById('filter-party').addEventListener('change', e => {
        currentFilters.party = e.target.value;
        applyFilters();
      });
      document.getElementById('filter-search').addEventListener('input', e => {
        currentFilters.q = e.target.value;
        applyFilters();
      });
      document.getElementById('filter-sort').addEventListener('change', e => {
        currentFilters.sort = e.target.value;
        applyFilters();
      });

      loadPoliticians();
    </script>
  </body>
</html>
