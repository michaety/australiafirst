---
import BaseHead from '../components/BaseHead.astro';

const SITE_TITLE = 'On The Record | Australian Politician Accountability';
const SITE_DESCRIPTION = 'A public accountability register for Australian federal politicians. Documented votes, donations, promises, and foreign ties — all sourced from public records.';
---
<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
    <style>
      *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

      body {
        background: #050505;
        color: #e8e8e8;
        font-family: 'Courier New', monospace;
        height: 100vh;
        overflow: hidden;
        display: flex;
        align-items: center;
        justify-content: center;
      }

      .scanlines {
        position: fixed; inset: 0;
        background: repeating-linear-gradient(0deg, transparent, transparent 2px, rgba(0,0,0,0.13) 2px, rgba(0,0,0,0.13) 4px);
        pointer-events: none; z-index: 50;
      }
      .vignette {
        position: fixed; inset: 0;
        background: radial-gradient(ellipse at center, transparent 30%, rgba(110,0,0,0.55) 100%);
        pointer-events: none; z-index: 2;
        animation: vignette-pulse 4s ease-in-out infinite;
      }
      @keyframes vignette-pulse {
        0%, 100% { opacity: 0.6; }
        50%       { opacity: 1; }
      }

      .corner { position: fixed; width: 44px; height: 44px; opacity: 0.25; z-index: 10; }
      .corner-tl { top: 24px; left: 24px; border-top: 1px solid #cc0000; border-left: 1px solid #cc0000; }
      .corner-tr { top: 24px; right: 24px; border-top: 1px solid #cc0000; border-right: 1px solid #cc0000; }
      .corner-bl { bottom: 24px; left: 24px; border-bottom: 1px solid #cc0000; border-left: 1px solid #cc0000; }
      .corner-br { bottom: 24px; right: 24px; border-bottom: 1px solid #cc0000; border-right: 1px solid #cc0000; }

      .splash {
        position: relative; z-index: 10;
        text-align: center; padding: 2rem;
        max-width: 800px; width: 100%;
      }

      .title-wrap {
        font-size: clamp(2.2rem, 9vw, 5.5rem);
        font-weight: 900; letter-spacing: 0.18em;
        line-height: 1; margin-bottom: 1.6rem; min-height: 1.2em;
      }
      .letter {
        display: inline-block; opacity: 0;
        animation: glitch-in 0.35s forwards;
        will-change: transform, opacity;
      }
      .letter-space { display: inline-block; width: 0.38em; }

      @keyframes glitch-in {
        0%   { opacity: 0; transform: translateY(-10px) skewX(-25deg); filter: blur(6px); color: #fff; }
        20%  { opacity: 1; transform: translateY(3px) skewX(6deg); color: #ff3333; filter: blur(0); }
        35%  { opacity: 0; transform: translateY(-1px) skewX(-2deg); }
        55%  { opacity: 1; transform: translateY(0) skewX(1deg); color: #cc0000; }
        75%  { opacity: 0.7; }
        100% { opacity: 1; transform: translateY(0) skewX(0); color: #e8e8e8; filter: blur(0); }
      }

      .tagline {
        color: #555; font-size: clamp(0.7rem, 1.8vw, 0.9rem);
        letter-spacing: 0.18em; text-transform: uppercase;
        opacity: 0; animation: fade-up 0.8s 2.6s forwards;
        margin-bottom: 3rem;
      }
      @keyframes fade-up {
        from { opacity: 0; transform: translateY(10px); }
        to   { opacity: 1; transform: translateY(0); }
      }

      .enter-btn {
        display: inline-block; background: transparent;
        border: 2px solid #cc0000; color: #cc0000;
        font-family: 'Courier New', monospace;
        font-size: clamp(0.8rem, 2vw, 1rem);
        font-weight: 900; letter-spacing: 0.35em; text-transform: uppercase;
        padding: 1rem 2.8rem; cursor: pointer;
        opacity: 0;
        animation: fade-up 0.8s 3.1s forwards, btn-pulse 2.2s 3.9s ease-in-out infinite;
        transition: background 0.15s, color 0.15s, transform 0.1s;
        text-decoration: none;
      }
      .enter-btn:hover { background: #cc0000; color: #050505; transform: scale(1.02); }
      .enter-btn:active { transform: scale(0.97); }

      @keyframes btn-pulse {
        0%, 100% { box-shadow: 0 0 8px rgba(204,0,0,0.5), 0 0 20px rgba(204,0,0,0.15); }
        50%       { box-shadow: 0 0 22px rgba(204,0,0,0.8), 0 0 55px rgba(204,0,0,0.35); }
      }

      .status-line {
        position: fixed; bottom: 22px; left: 50%; transform: translateX(-50%);
        font-size: 0.6rem; letter-spacing: 0.25em; color: #1e1e1e; z-index: 10; white-space: nowrap;
      }
    </style>
  </head>
  <body>
    <div class="scanlines"></div>
    <div class="vignette"></div>
    <div class="corner corner-tl"></div>
    <div class="corner corner-tr"></div>
    <div class="corner corner-bl"></div>
    <div class="corner corner-br"></div>

    <div class="splash">
      <div class="title-wrap" id="title"></div>
      <div class="tagline">Every politician. Every donor. Every foreign tie.</div>
      <button class="enter-btn" id="enter-btn">ENTER THE REGISTER ▶</button>
    </div>

    <div class="status-line">ONTHERECORD.FYI — FEDERAL POLITICIAN ACCOUNTABILITY REGISTER</div>

    <script>
      import { playBeep } from '../scripts/sounds';

      const text = 'ON THE RECORD';
      const container = document.getElementById('title')!;
      let delay = 0.08;
      for (const ch of text) {
        if (ch === ' ') {
          const sp = document.createElement('span');
          sp.className = 'letter-space';
          container.appendChild(sp);
        } else {
          const span = document.createElement('span');
          span.className = 'letter';
          span.textContent = ch;
          span.style.animationDelay = `${delay}s`;
          container.appendChild(span);
          delay += 0.11;
        }
      }

      document.getElementById('enter-btn')!.addEventListener('click', () => {
        playBeep();
        setTimeout(() => { window.location.href = '/explore'; }, 130);
      });
    </script>
  </body>
</html>
