---
import BaseHead from '../../components/BaseHead.astro';

export const prerender = false;

const { id } = Astro.params;
---
<!doctype html>
<html lang="en">
  <head>
    <BaseHead title="Politician Profile | Australia First" description="Accountability profile for Australian federal politician" />
  </head>
  <body style="margin:0;padding:0;background:#050505;color:#e8e8e8;font-family:'Courier New',monospace;">
    <div id="page-wrap" style="min-height:100vh;display:flex;flex-direction:column;align-items:center;padding:40px 20px;gap:32px;box-sizing:border-box;">
      <div style="text-align:center;max-width:680px;width:100%;">
        <div style="color:#c8001a;font-size:11px;letter-spacing:6px;margin-bottom:8px;">&#9670; AUSTRALIA FIRST &#9670;</div>
        <div style="color:#f0f0f0;font-size:28px;font-weight:900;letter-spacing:-1px;margin-bottom:8px;">PUBLIC ACCOUNTABILITY REGISTER</div>
        <div style="color:#444;font-size:12px;line-height:1.6;">Every politician. Every donor. Every broken promise. Every foreign tie.<br>All public data. No spin.</div>
      </div>

      <div id="mugshot-card" style="background:#0a0a0a;border:1px solid #1a1a1a;border-radius:4px;overflow:hidden;max-width:680px;width:100%;">
        <div style="text-align:center;padding:60px;color:#333;font-size:12px;">Loading profile...</div>
      </div>

      <div style="color:#222;font-size:10px;text-align:center;max-width:500px;line-height:1.8;">
        Data sources: Australian Electoral Commission &middot; OpenAustralia &middot; TheyVoteForYou &middot;
        Parliament of Australia &middot; ASIC &middot; Foreign Influence Transparency Scheme
      </div>
    </div>

    <script define:vars={{ politicianId: id }}>
      function esc(s) {
        if (!s) return '';
        const d = document.createElement('div');
        d.textContent = s;
        return d.innerHTML;
      }

      function formatAmount(cents) {
        if (!cents) return 'Undisclosed';
        return '$' + (cents / 100).toLocaleString('en-AU', { minimumFractionDigits: 0, maximumFractionDigits: 0 });
      }

      function formatDate(d) {
        if (!d) return '';
        return new Date(d).toLocaleDateString('en-AU', { year: 'numeric', month: 'short', day: 'numeric' });
      }

      function donorFlag(amountCents) {
        if (!amountCents) return '⚪';
        if (amountCents >= 10000000) return '🔴';
        if (amountCents >= 2000000) return '🟡';
        return '🟢';
      }

      function riskBadgeStyle(r) {
        var level = (r || 'low').toLowerCase();
        var base = 'font-size:10px;font-weight:900;padding:2px 7px;border-radius:2px;letter-spacing:1px;';
        if (level === 'high' || level === 'critical') return base + 'background:#ff2b2b;color:#fff;';
        if (level === 'medium') return base + 'background:#ff8c00;color:#000;';
        return base + 'background:#2bff6e;color:#000;';
      }

      function promiseBorderColor(st) {
        if (st === 'kept') return '#2bff6e';
        if (st === 'broken') return '#c8001a';
        if (st === 'partial') return '#ff8c00';
        return '#666';
      }

      function promiseStatusColor(st) {
        if (st === 'kept') return '#2bff6e';
        if (st === 'broken') return '#c8001a';
        if (st === 'partial') return '#ff8c00';
        return '#666';
      }

      var tabNames = ['actions', 'donors', 'promises', 'foreign'];

      function switchTab(activeTab) {
        tabNames.forEach(function(t) {
          var btn = document.getElementById('tab-btn-' + t);
          var panel = document.getElementById('panel-' + t);
          if (t === activeTab) {
            btn.style.background = '#111';
            btn.style.borderBottomColor = '#c8001a';
            btn.style.color = '#f0f0f0';
            panel.style.display = 'block';
          } else {
            btn.style.background = 'transparent';
            btn.style.borderBottomColor = 'transparent';
            btn.style.color = '#444';
            panel.style.display = 'none';
          }
        });
      }

      async function loadProfile() {
        var card = document.getElementById('mugshot-card');
        try {
          var res = await fetch('/api/v1/politicians/' + politicianId + '.json');
          if (res.status === 404) {
            card.innerHTML = '<div style="text-align:center;padding:60px;color:#333;font-size:12px;">Politician not found.</div>';
            return;
          }
          var data = await res.json();
          var p = data.politician;
          var actions = data.actions || [];
          var donations = data.donations || [];
          var promises = data.promises || [];
          var foreignTies = data.foreignTies || [];

          var caseNum = 'AF-' + (p.id || '').replace(/[^0-9]/g, '').slice(0, 6);
          var chamberLabel = p.chamber === 'senate' ? 'Senator' : 'Member of Parliament';
          var brokenCount = promises.filter(function(pr) { return pr.status === 'broken'; }).length;

          var photoImgHtml = p.photoUrl
            ? '<img src="' + esc(p.photoUrl) + '" alt="' + esc(p.name) + '" style="width:100%;height:100%;object-fit:cover;object-position:top;filter:grayscale(85%) contrast(1.4) brightness(0.75) sepia(20%);display:block;" onerror="this.style.display=\'none\';this.nextElementSibling.style.display=\'flex\'">'
            : '';
          var noPhotoDisplay = p.photoUrl ? 'none' : 'flex';

          // Build actions HTML
          var actionsHtml = '';
          if (actions.length === 0) {
            actionsHtml = '<div style="color:#333;font-size:12px;text-align:center;padding:40px 0;">No documented actions on record.</div>';
          } else {
            actions.forEach(function(a, i) {
              actionsHtml += '<div style="display:flex;gap:12px;align-items:flex-start;padding:10px;background:#0d0d0d;border:1px solid #1a1a1a;border-left:3px solid #c8001a;margin-bottom:8px;">'
                + '<span style="color:#c8001a;font-size:11px;font-weight:900;min-width:20px;">' + String(i + 1).padStart(2, '0') + '</span>'
                + '<div>'
                + '<div style="color:#ccc;font-size:12px;line-height:1.5;">' + esc(a.title) + '</div>'
                + (a.description ? '<div style="color:#888;font-size:11px;line-height:1.4;margin-top:4px;">' + esc(a.description) + '</div>' : '')
                + '<div style="margin-top:4px;">'
                + (a.date ? '<span style="font-size:10px;color:#555;margin-right:8px;">' + formatDate(a.date) + '</span>' : '')
                + (a.category ? '<span style="font-size:10px;color:#555;margin-right:8px;">' + esc(a.category) + '</span>' : '')
                + (a.sourceUrl ? '<a href="' + esc(a.sourceUrl) + '" target="_blank" rel="noopener" style="font-size:10px;color:#4499ff;margin-right:8px;text-decoration:none;">Source ↗</a>' : '')
                + (a.evidenceUrl ? '<a href="' + esc(a.evidenceUrl) + '" target="_blank" rel="noopener" style="font-size:10px;color:#4499ff;margin-right:8px;text-decoration:none;">Evidence ↗</a>' : '')
                + '</div></div></div>';
            });
          }

          // Build donations HTML
          var donationsHtml = '';
          if (donations.length === 0) {
            donationsHtml = '<div style="color:#333;font-size:12px;text-align:center;padding:40px 0;">No donation records found.</div>';
          } else {
            donations.forEach(function(d) {
              donationsHtml += '<div style="display:flex;justify-content:space-between;align-items:center;padding:10px;background:#0d0d0d;border:1px solid #1a1a1a;margin-bottom:8px;">'
                + '<div style="display:flex;gap:10px;align-items:center;">'
                + '<span style="font-size:14px;">' + donorFlag(d.amountCents) + '</span>'
                + '<div><div style="color:#ccc;font-size:12px;">' + esc(d.donorName) + '</div>'
                + '<div style="color:#444;font-size:10px;">' + (d.year || '') + '</div></div></div>'
                + '<div style="color:#c8001a;font-size:14px;font-weight:900;">' + formatAmount(d.amountCents) + '</div>'
                + '</div>';
            });
            donationsHtml += '<div style="color:#333;font-size:10px;margin-top:4px;">Source: Australian Electoral Commission transparency.aec.gov.au</div>';
          }

          // Build promises HTML
          var promisesHtml = '';
          if (promises.length === 0) {
            promisesHtml = '<div style="color:#333;font-size:12px;text-align:center;padding:40px 0;">No election promises on record.</div>';
          } else {
            promises.forEach(function(pr) {
              var st = pr.status || 'pending';
              var icon = st === 'kept' ? '✓ KEPT' : st === 'broken' ? '✗ BROKEN' : st === 'partial' ? '~ PARTIAL' : '? PENDING';
              promisesHtml += '<div style="padding:12px;background:#0d0d0d;border:1px solid #1a1a1a;border-left:3px solid ' + promiseBorderColor(st) + ';margin-bottom:10px;">'
                + '<div style="color:#888;font-size:12px;font-style:italic;margin-bottom:6px;">"' + esc(pr.title) + '"</div>'
                + '<div style="display:flex;gap:8px;align-items:flex-start;">'
                + '<span style="font-size:10px;font-weight:900;letter-spacing:1px;min-width:60px;color:' + promiseStatusColor(st) + ';">' + icon + '</span>'
                + '<span style="color:#aaa;font-size:12px;">' + esc(pr.description || pr.notes || '') + '</span>'
                + '</div>'
                + '<div style="margin-top:6px;">'
                + (pr.madeDate ? '<span style="font-size:10px;color:#555;margin-right:8px;">Made: ' + formatDate(pr.madeDate) + '</span>' : '')
                + (pr.sourceUrl ? '<a href="' + esc(pr.sourceUrl) + '" target="_blank" rel="noopener" style="font-size:10px;color:#4499ff;margin-right:8px;text-decoration:none;">Source ↗</a>' : '')
                + (pr.evidenceUrl ? '<a href="' + esc(pr.evidenceUrl) + '" target="_blank" rel="noopener" style="font-size:10px;color:#4499ff;margin-right:8px;text-decoration:none;">Evidence ↗</a>' : '')
                + '</div></div>';
            });
          }

          // Build foreign ties HTML
          var foreignHtml = '';
          if (foreignTies.length === 0) {
            foreignHtml = '<div style="color:#333;font-size:12px;text-align:center;padding:40px 0;">No foreign ties on record.</div>';
          } else {
            foreignTies.forEach(function(f) {
              foreignHtml += '<div style="display:flex;justify-content:space-between;align-items:center;padding:10px;background:#0d0d0d;border:1px solid #1a1a1a;margin-bottom:8px;">'
                + '<div><div style="color:#ccc;font-size:12px;margin-bottom:3px;">' + esc(f.entityName) + (f.entityCountry ? ' (' + esc(f.entityCountry) + ')' : '') + '</div>'
                + '<div style="color:#555;font-size:11px;">' + esc(f.relationshipType || f.description || '') + '</div></div>'
                + '<span style="' + riskBadgeStyle(f.riskRating) + '">' + (f.riskRating || 'LOW').toUpperCase() + '</span>'
                + '</div>';
            });
          }

          var tabBtnBase = 'flex:1;padding:10px 4px;border:none;font-size:9px;font-weight:900;letter-spacing:1px;cursor:pointer;font-family:\'Courier New\',monospace;border-bottom:2px solid transparent;';

          card.innerHTML =
            // Red header
            '<div style="background:#c8001a;padding:8px 16px;display:flex;justify-content:space-between;align-items:center;">'
              + '<span style="color:#fff;font-size:11px;font-weight:900;letter-spacing:3px;">AUSTRALIA FIRST — PUBLIC RECORD</span>'
              + '<span style="color:rgba(255,255,255,0.7);font-size:10px;letter-spacing:1px;">CASE #' + esc(caseNum) + '</span>'
            + '</div>'

            // Mugshot row
            + '<div style="display:flex;border-bottom:1px solid #1e1e1e;">'

              // Photo column
              + '<div style="position:relative;width:200px;min-width:200px;background:#111;overflow:hidden;">'
                // Height ruler
                + '<div style="position:absolute;right:0;top:0;bottom:0;width:28px;background:#0a0a0a;border-left:1px solid #222;display:flex;flex-direction:column;justify-content:space-between;padding:8px 0;z-index:2;">'
                  + '<span style="color:#444;font-size:7px;text-align:center;border-bottom:1px solid #1a1a1a;padding-bottom:2px;">6\'2"</span>'
                  + '<span style="color:#444;font-size:7px;text-align:center;border-bottom:1px solid #1a1a1a;padding-bottom:2px;">6\'0"</span>'
                  + '<span style="color:#444;font-size:7px;text-align:center;border-bottom:1px solid #1a1a1a;padding-bottom:2px;">5\'10"</span>'
                  + '<span style="color:#444;font-size:7px;text-align:center;border-bottom:1px solid #1a1a1a;padding-bottom:2px;">5\'8"</span>'
                  + '<span style="color:#444;font-size:7px;text-align:center;border-bottom:1px solid #1a1a1a;padding-bottom:2px;">5\'6"</span>'
                + '</div>'
                // Photo frame
                + '<div style="width:172px;height:220px;overflow:hidden;position:relative;background:#1a1a1a;">'
                  + photoImgHtml
                  + '<div style="width:100%;height:100%;display:' + noPhotoDisplay + ';align-items:center;justify-content:center;color:#333;font-size:11px;text-align:center;padding:10px;">PHOTO<br>UNAVAILABLE</div>'
                  + '<div style="position:absolute;inset:0;background:radial-gradient(ellipse at center,transparent 40%,rgba(0,0,0,0.7) 100%);pointer-events:none;"></div>'
                  + '<div style="position:absolute;inset:0;background-image:repeating-linear-gradient(0deg,transparent,transparent 2px,rgba(0,0,0,0.08) 2px,rgba(0,0,0,0.08) 4px);pointer-events:none;"></div>'
                + '</div>'
                // Booking strip
                + '<div style="background:#0a0a0a;border-top:1px solid #1e1e1e;padding:8px;text-align:center;">'
                  + '<div style="color:#c8001a;font-size:10px;letter-spacing:2px;margin-bottom:3px;">BOOKING DATE</div>'
                  + '<div style="color:#666;font-size:11px;">Since ' + esc(p.jurisdiction || 'Unknown') + '</div>'
                + '</div>'
              + '</div>'

              // Identity column
              + '<div style="flex:1;padding:20px;border-left:1px solid #1a1a1a;display:flex;flex-direction:column;gap:12px;">'
                + '<div>'
                  + '<div style="color:#444;font-size:10px;letter-spacing:3px;margin-bottom:4px;">FULL NAME</div>'
                  + '<div style="color:#f0f0f0;font-size:22px;font-weight:900;line-height:1.1;letter-spacing:-0.5px;">' + esc(p.name).toUpperCase() + '</div>'
                + '</div>'
                + '<div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">'
                  + '<div><div style="color:#444;font-size:9px;letter-spacing:2px;margin-bottom:3px;">OFFICE</div><div style="color:#aaa;font-size:12px;">' + esc(chamberLabel) + '</div></div>'
                  + '<div><div style="color:#444;font-size:9px;letter-spacing:2px;margin-bottom:3px;">PARTY</div><div style="color:#aaa;font-size:12px;">' + esc(p.partyName || p.party || 'Unknown') + '</div></div>'
                  + '<div><div style="color:#444;font-size:9px;letter-spacing:2px;margin-bottom:3px;">ELECTORATE</div><div style="color:#aaa;font-size:12px;">' + esc(p.electorate || 'N/A') + '</div></div>'
                  + '<div><div style="color:#444;font-size:9px;letter-spacing:2px;margin-bottom:3px;">STATUS</div><div style="color:#c8001a;font-weight:900;letter-spacing:2px;font-size:12px;">IN POWER</div></div>'
                + '</div>'
                + '<div style="display:flex;gap:8px;flex-wrap:wrap;margin-top:4px;">'
                  + '<div style="background:#111;border:1px solid #1e1e1e;border-radius:2px;padding:4px 10px;text-align:center;"><div style="color:#c8001a;font-size:16px;font-weight:900;">' + actions.length + '</div><div style="color:#444;font-size:8px;letter-spacing:1px;">ACTIONS</div></div>'
                  + '<div style="background:#111;border:1px solid #1e1e1e;border-radius:2px;padding:4px 10px;text-align:center;"><div style="color:#c8001a;font-size:16px;font-weight:900;">' + donations.length + '</div><div style="color:#444;font-size:8px;letter-spacing:1px;">DONORS</div></div>'
                  + '<div style="background:#111;border:1px solid #1e1e1e;border-radius:2px;padding:4px 10px;text-align:center;"><div style="color:#c8001a;font-size:16px;font-weight:900;">' + brokenCount + '</div><div style="color:#444;font-size:8px;letter-spacing:1px;">BROKEN PROMISES</div></div>'
                  + '<div style="background:#111;border:1px solid #1e1e1e;border-radius:2px;padding:4px 10px;text-align:center;"><div style="color:#c8001a;font-size:16px;font-weight:900;">' + foreignTies.length + '</div><div style="color:#444;font-size:8px;letter-spacing:1px;">FOREIGN LINKS</div></div>'
                + '</div>'
              + '</div>'

            + '</div>'

            // Tabs
            + '<div style="display:flex;border-bottom:1px solid #1a1a1a;background:#080808;">'
              + '<button id="tab-btn-actions" style="' + tabBtnBase + 'background:#111;border-bottom-color:#c8001a;color:#f0f0f0;">ACTIONS</button>'
              + '<button id="tab-btn-donors" style="' + tabBtnBase + 'background:transparent;color:#444;">FOLLOW THE MONEY</button>'
              + '<button id="tab-btn-promises" style="' + tabBtnBase + 'background:transparent;color:#444;">THEY PROMISED</button>'
              + '<button id="tab-btn-foreign" style="' + tabBtnBase + 'background:transparent;color:#444;">FOREIGN TIES</button>'
            + '</div>'

            // Panels
            + '<div id="panel-actions" style="display:block;padding:16px;min-height:200px;">'
              + '<div style="color:#444;font-size:9px;letter-spacing:2px;margin-bottom:8px;">DOCUMENTED ACTIONS AGAINST THE NATIONAL INTEREST</div>'
              + actionsHtml
            + '</div>'

            + '<div id="panel-donors" style="display:none;padding:16px;min-height:200px;">'
              + '<div style="color:#444;font-size:9px;letter-spacing:2px;margin-bottom:8px;">SOURCE: AEC TRANSPARENCY REGISTER — WHO PAID THEM</div>'
              + donationsHtml
            + '</div>'

            + '<div id="panel-promises" style="display:none;padding:16px;min-height:200px;">'
              + '<div style="color:#444;font-size:9px;letter-spacing:2px;margin-bottom:8px;">WHAT THEY SAID VS WHAT THEY DID</div>'
              + promisesHtml
            + '</div>'

            + '<div id="panel-foreign" style="display:none;padding:16px;min-height:200px;">'
              + '<div style="color:#444;font-size:9px;letter-spacing:2px;margin-bottom:8px;">FOREIGN ENTITY ASSOCIATIONS & RISK ASSESSMENT</div>'
              + foreignHtml
            + '</div>'

            // Footer
            + '<div style="border-top:1px solid #1a1a1a;padding:10px 16px;display:flex;justify-content:space-between;align-items:center;background:#080808;">'
              + '<span style="color:#2a2a2a;font-size:10px;letter-spacing:1px;">ALL DATA SOURCED FROM PUBLIC RECORDS</span>'
              + '<span style="color:#c8001a;font-size:10px;letter-spacing:2px;font-weight:900;">AUSTRALIAFIRST.XYZ</span>'
            + '</div>';

          tabNames.forEach(function(t) {
            document.getElementById('tab-btn-' + t).addEventListener('click', function() { switchTab(t); });
          });

          document.title = p.name.toUpperCase() + ' | Australia First';

        } catch (e) {
          card.innerHTML = '<div style="text-align:center;padding:60px;color:#333;font-size:12px;">Failed to load profile.</div>';
        }
      }

      loadProfile();
    </script>
  </body>
</html>
