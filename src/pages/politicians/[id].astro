---
import BaseHead from '../../components/BaseHead.astro';

export const prerender = false;

const { id } = Astro.params;
---
<!doctype html>
<html lang="en">
  <head>
    <BaseHead title="Politician Profile | On The Record" description="Accountability profile for Australian federal politician" />
    <style>
      .back-btn {
        position: fixed; top: 16px; left: 16px; z-index: 200;
        background: transparent; border: 1px solid #2a2a2a; color: #444;
        font-family: 'Courier New', monospace; font-size: 0.7rem; font-weight: 700;
        letter-spacing: 0.15em; text-transform: uppercase; padding: 0.4rem 0.9rem;
        cursor: pointer; transition: all 0.12s;
      }
      .back-btn:hover { border-color: #cc0000; color: #cc0000; }
      .stat-box { position: relative; cursor: default; }
      .stat-tip {
        display: none; position: absolute; bottom: calc(100% + 8px); left: 50%; transform: translateX(-50%);
        background: #080808; border: 1px solid #cc0000; color: #888;
        font-family: 'Courier New', monospace; font-size: 0.65rem; line-height: 1.5;
        padding: 6px 10px; white-space: nowrap; z-index: 300; pointer-events: none; text-align: center;
        min-width: 200px;
      }
      .stat-box:hover .stat-tip { display: block; }
      @keyframes ai-pulse {
        0%, 100% { opacity: 0.45; }
        50% { opacity: 0.85; }
      }
      .ai-loading { animation: ai-pulse 1.6s ease-in-out infinite; }

      /* ── Typewriter effect for profile fields ── */
      @keyframes type-cursor-blink {
        0%, 100% { opacity: 1; }
        50% { opacity: 0; }
      }
      .type-field-cursor {
        display: inline-block;
        width: 0.6em; height: 0.85em;
        background: #cc0000;
        vertical-align: bottom;
        margin-left: 2px;
        animation: type-cursor-blink 0.7s step-end infinite;
      }
      .type-field-cursor.done { display: none; }
    </style>
  </head>
  <body style="margin:0;padding:0;background:#050505;color:#e8e8e8;font-family:'Courier New',monospace;">
    <button class="back-btn" id="back-btn">&#8592; BACK TO REGISTER</button>
    <script>
      import { playBeep, playSwipe, playAlert, playError, playTypeTickName, playTypeTickDays, playAccessGranted } from '../../scripts/sounds';
      (window as any).__sounds = { playBeep, playSwipe, playAlert, playError, playTypeTickName, playTypeTickDays, playAccessGranted };
      document.getElementById('back-btn')!.addEventListener('click', () => {
        playBeep();
        if (window.history.length > 1) { setTimeout(() => window.history.back(), 100); }
        else { setTimeout(() => { window.location.href = '/explore'; }, 100); }
      });
    </script>
    <div id="page-wrap" style="min-height:100vh;display:flex;flex-direction:column;align-items:center;padding:40px 20px;gap:32px;box-sizing:border-box;">
      <div style="text-align:center;max-width:680px;width:100%;">
        <div style="color:#c8001a;font-size:11px;letter-spacing:6px;margin-bottom:8px;">&#9670; ON THE RECORD &#9670;</div>
        <div style="color:#f0f0f0;font-size:28px;font-weight:900;letter-spacing:-1px;margin-bottom:8px;">PUBLIC ACCOUNTABILITY REGISTER</div>
        <div style="color:#444;font-size:12px;line-height:1.6;">Every politician. Every donor. Every broken promise. Every foreign tie.<br>All public data. No spin.</div>
      </div>

      <div id="mugshot-card" style="background:#0a0a0a;border:1px solid #1a1a1a;border-radius:4px;overflow:hidden;max-width:680px;width:100%;">
        <div style="text-align:center;padding:60px;color:#333;font-size:12px;">Loading profile...</div>
      </div>

      <div style="color:#222;font-size:10px;text-align:center;max-width:500px;line-height:1.8;">
        Data sources: Australian Electoral Commission &middot; OpenAustralia &middot; TheyVoteForYou &middot;
        Parliament of Australia &middot; ASIC &middot; Foreign Influence Transparency Scheme
      </div>
    </div>

    <script define:vars={{ politicianId: id }}>
      function esc(s) {
        if (!s) return '';
        var d = document.createElement('div');
        d.textContent = s;
        return d.innerHTML;
      }

      function escAttr(s) {
        if (!s) return '';
        return String(s)
          .replace(/&/g, '&amp;')
          .replace(/"/g, '&quot;')
          .replace(/</g, '&lt;')
          .replace(/>/g, '&gt;');
      }

      function formatAmount(cents) {
        if (!cents) return 'Undisclosed';
        return '$' + (cents / 100).toLocaleString('en-AU', { minimumFractionDigits: 0, maximumFractionDigits: 0 });
      }

      function formatDate(d) {
        if (!d) return '';
        return new Date(d).toLocaleDateString('en-AU', { year: 'numeric', month: 'short', day: 'numeric' });
      }

      function donorFlag(amountCents) {
        if (!amountCents) return '⚪';
        if (amountCents >= 10000000) return '🔴';
        if (amountCents >= 2000000) return '🟡';
        return '🟢';
      }

      function riskBadgeStyle(r) {
        var level = (r || 'low').toLowerCase();
        var base = 'font-size:10px;font-weight:900;padding:2px 7px;border-radius:2px;letter-spacing:1px;';
        if (level === 'high' || level === 'critical') return base + 'background:#ff2b2b;color:#fff;';
        if (level === 'medium') return base + 'background:#ff8c00;color:#000;';
        return base + 'background:#2bff6e;color:#000;';
      }

      function promiseBorderColor(st) {
        if (st === 'kept') return '#2bff6e';
        if (st === 'broken') return '#c8001a';
        if (st === 'partial') return '#ff8c00';
        return '#666';
      }

      function promiseStatusColor(st) {
        if (st === 'kept') return '#2bff6e';
        if (st === 'broken') return '#c8001a';
        if (st === 'partial') return '#ff8c00';
        return '#666';
      }

      // ── Policy helpers ──────────────────────────────────────────────────────

      function policyStanceLabel(pct) {
        if (pct == null) return 'NO DATA';
        if (pct >= 80) return 'STRONG SUPPORTER';
        if (pct >= 60) return 'MOSTLY SUPPORTS';
        if (pct > 40) return 'MIXED RECORD';
        if (pct >= 20) return 'MOSTLY OPPOSES';
        return 'STRONG OPPONENT';
      }

      function policyStanceColor(pct) {
        if (pct == null) return '#555';
        if (pct >= 70) return '#2bff6e';
        if (pct >= 55) return '#88cc88';
        if (pct >= 45) return '#ff8c00';
        if (pct >= 30) return '#ff6644';
        return '#c8001a';
      }

      function policyVoteLabel(pct) {
        if (pct == null) return '';
        if (pct > 55) return 'VOTES FOR';
        if (pct < 45) return 'VOTES AGAINST';
        return 'MIXED';
      }

      // ── Shared collapse/expand ──────────────────────────────────────────────

      window.__showSection = function(toggleId, className) {
        document.querySelectorAll('.' + className).forEach(function(el) {
          el.style.display = el.getAttribute('data-display') || 'block';
        });
        var toggle = document.getElementById(toggleId);
        if (toggle) toggle.style.display = 'none';
      };

      function showMoreBtn(toggleId, className, label) {
        return '<div id="' + toggleId + '" style="text-align:center;padding:6px 0;">'
          + '<button onclick="window.__showSection(\'' + toggleId + '\',\'' + className + '\')"'
          + ' style="background:transparent;border:1px solid #2a2a2a;color:#555;font-family:\'Courier New\',monospace;font-size:9px;letter-spacing:2px;padding:5px 14px;cursor:pointer;"'
          + ' onmouseover="this.style.borderColor=\'#c8001a\';this.style.color=\'#c8001a\';"'
          + ' onmouseout="this.style.borderColor=\'#2a2a2a\';this.style.color=\'#555\';">'
          + label
          + '</button></div>';
      }

      // ── AI summary card ─────────────────────────────────────────────────────

      function aiSummaryCardHtml(tabName) {
        return '<div id="ai-card-' + tabName + '" style="background:#0d0d0d;border:1px solid #1e1e1e;border-left:3px solid #c8001a;padding:14px;margin-bottom:16px;">'
          + '<div style="color:#c8001a;font-size:8px;letter-spacing:3px;font-weight:900;margin-bottom:8px;">▸ AI SUMMARY</div>'
          + '<div id="ai-summary-' + tabName + '" class="ai-loading" style="color:#555;font-size:12px;line-height:1.7;font-style:italic;">Generating summary...</div>'
          + '</div>';
      }

      // ── Policy HTML ─────────────────────────────────────────────────────────

      function buildPolicyRow(ps, hidden, hiddenClass) {
        var pct = ps.agreement_pct != null ? Math.round(ps.agreement_pct) : null;
        var barColor = pct == null ? '#333' : pct >= 60 ? '#2bff6e' : pct <= 40 ? '#c8001a' : '#ff8c00';
        var voteLabel = policyVoteLabel(pct);
        var desc = escAttr(ps.policy_description || '');
        var classAttr = hidden ? ' class="' + hiddenClass + '" data-display="block"' : '';
        return '<div' + classAttr + ' style="' + (hidden ? 'display:none;' : '') + 'padding:10px;background:#0d0d0d;border:1px solid #1a1a1a;margin-bottom:6px;" title="' + desc + '">'
          + '<div style="display:flex;justify-content:space-between;align-items:baseline;margin-bottom:4px;">'
            + '<div style="color:#ccc;font-size:12px;flex:1;padding-right:12px;">' + esc(ps.policy_name) + '</div>'
            + '<span style="color:' + policyStanceColor(pct) + ';font-size:9px;font-weight:900;letter-spacing:1px;white-space:nowrap;">' + policyStanceLabel(pct) + '</span>'
          + '</div>'
          + '<div style="height:4px;background:#1a1a1a;border-radius:2px;overflow:hidden;">'
            + (pct != null ? '<div style="height:100%;width:' + pct + '%;background:' + barColor + ';border-radius:2px;"></div>' : '')
          + '</div>'
          + '<div style="display:flex;justify-content:space-between;margin-top:3px;">'
            + '<span style="color:#333;font-size:9px;">OPPOSES</span>'
            + (voteLabel ? '<span style="color:#555;font-size:9px;letter-spacing:1px;">' + voteLabel + '</span>' : '')
            + '<span style="color:#333;font-size:9px;">SUPPORTS</span>'
          + '</div>'
          + '</div>';
      }

      function buildPolicySection(title, items, sectionId) {
        if (items.length === 0) return '';
        var LIMIT = 8;
        var hiddenClass = sectionId + '-hidden';
        var toggleId = sectionId + '-toggle';
        var html = '<div style="margin-bottom:20px;">'
          + '<div style="color:#555;font-size:9px;letter-spacing:3px;margin-bottom:8px;padding-bottom:4px;border-bottom:1px solid #1a1a1a;">'
            + title + ' (' + items.length + ')'
          + '</div>';
        items.forEach(function(ps, i) { html += buildPolicyRow(ps, i >= LIMIT, hiddenClass); });
        if (items.length > LIMIT) html += showMoreBtn(toggleId, hiddenClass, 'SHOW ALL (' + items.length + ')');
        return html + '</div>';
      }

      function buildPolicyHtml(policyScores) {
        if (policyScores.length === 0) {
          return '<div style="color:#333;font-size:12px;text-align:center;padding:40px 0;">No policy voting data on record.</div>';
        }
        var sorted = policyScores.slice().sort(function(a, b) {
          var aAbs = a.agreement_pct != null ? Math.abs(a.agreement_pct - 50) : -1;
          var bAbs = b.agreement_pct != null ? Math.abs(b.agreement_pct - 50) : -1;
          return bAbs - aAbs;
        });
        var decisive = sorted.filter(function(ps) {
          return ps.agreement_pct != null && (ps.agreement_pct > 70 || ps.agreement_pct < 30);
        });
        var contested = sorted.filter(function(ps) {
          return ps.agreement_pct != null && ps.agreement_pct >= 30 && ps.agreement_pct <= 70
            && Math.abs((ps.agreement_pct || 0) - 50) > 0.01;
        });
        var unclear = sorted.filter(function(ps) {
          return ps.agreement_pct == null || Math.abs((ps.agreement_pct || 0) - 50) < 0.01;
        });
        var html = aiSummaryCardHtml('policy');
        html += buildPolicySection('DECISIVE VOTES', decisive, 'policy-decisive');
        html += buildPolicySection('CONTESTED', contested, 'policy-contested');
        html += buildPolicySection('NO CLEAR POSITION', unclear, 'policy-unclear');
        html += '<div style="color:#333;font-size:10px;margin-top:4px;">Source: They Vote For You — theyvoteforyou.org.au</div>';
        return html;
      }

      // ── Actions HTML ────────────────────────────────────────────────────────

      function buildActionsHtml(actions) {
        if (actions.length === 0) {
          return '<div style="color:#333;font-size:12px;text-align:center;padding:40px 0;">No documented actions on record.</div>';
        }
        var sorted = actions.slice().sort(function(a, b) {
          if (!a.date && !b.date) return 0;
          if (!a.date) return 1;
          if (!b.date) return -1;
          return new Date(b.date).getTime() - new Date(a.date).getTime();
        });
        var categories = {};
        sorted.forEach(function(a) {
          var cat = (a.category || 'UNCATEGORISED').toUpperCase();
          if (!categories[cat]) categories[cat] = [];
          categories[cat].push(a);
        });
        var totalActions = actions.length;
        var COLLAPSE_AT = 5;
        var html = aiSummaryCardHtml('actions');
        Object.keys(categories).sort().forEach(function(cat) {
          var items = categories[cat];
          var sectionId = 'actions-cat-' + cat.replace(/[^a-z0-9]/gi, '').toLowerCase();
          var hiddenClass = sectionId + '-hidden';
          var toggleId = sectionId + '-toggle';
          var collapseAt = totalActions > 10 ? COLLAPSE_AT : items.length;
          html += '<div style="margin-bottom:20px;">'
            + '<div style="color:#555;font-size:9px;letter-spacing:3px;margin-bottom:8px;padding-bottom:4px;border-bottom:1px solid #1a1a1a;">'
              + esc(cat) + ' (' + items.length + ')'
            + '</div>';
          items.forEach(function(a, i) {
            var hidden = i >= collapseAt;
            var classAttr = hidden ? ' class="' + hiddenClass + '" data-display="flex"' : '';
            html += '<div' + classAttr + ' style="' + (hidden ? 'display:none;' : 'display:flex;') + 'gap:12px;align-items:flex-start;padding:10px;background:#0d0d0d;border:1px solid #1a1a1a;border-left:3px solid #c8001a;margin-bottom:8px;">'
              + '<div>'
              + '<div style="color:#ccc;font-size:12px;line-height:1.5;">' + esc(a.title) + '</div>'
              + (a.description ? '<div style="color:#888;font-size:11px;line-height:1.4;margin-top:4px;">' + esc(a.description) + '</div>' : '')
              + '<div style="margin-top:4px;">'
              + (a.date ? '<span style="font-size:10px;color:#555;margin-right:8px;">' + formatDate(a.date) + '</span>' : '')
              + (a.category ? '<span style="font-size:10px;color:#444;margin-right:8px;border:1px solid #1e1e1e;padding:1px 5px;">' + esc(a.category) + '</span>' : '')
              + (a.sourceUrl ? '<a href="' + esc(a.sourceUrl) + '" target="_blank" rel="noopener" style="font-size:10px;color:#4499ff;margin-right:8px;text-decoration:none;">Source ↗</a>' : '')
              + (a.evidenceUrl ? '<a href="' + esc(a.evidenceUrl) + '" target="_blank" rel="noopener" style="font-size:10px;color:#4499ff;margin-right:8px;text-decoration:none;">Evidence ↗</a>' : '')
              + '</div></div></div>';
          });
          if (items.length > collapseAt) {
            html += showMoreBtn(toggleId, hiddenClass, 'SHOW MORE (' + (items.length - collapseAt) + ' more)');
          }
          html += '</div>';
        });
        return html;
      }

      // ── Donations HTML ──────────────────────────────────────────────────────

      function buildDonationsHtml(donations, partyDonations, p) {
        var allDonations = donations.length > 0 ? donations : partyDonations;
        var isParty = donations.length === 0 && partyDonations.length > 0;
        if (allDonations.length === 0) {
          return '<div style="color:#333;font-size:12px;text-align:center;padding:40px 0;">No donation records found.</div>';
        }
        var totalCents = allDonations.reduce(function(sum, d) { return sum + (d.amountCents || 0); }, 0);
        var html = '';

        // Plain English note
        html += '<div style="color:#888;font-size:11px;line-height:1.5;margin-bottom:12px;padding:10px 12px;background:#0d0d0d;border:1px solid #1a1a1a;border-left:3px solid #333;">'
          + 'This shows who has financially supported ' + esc(p.name) + (isParty ? ' or their party' : '') + '.'
          + '</div>';

        // Total amount
        if (totalCents > 0) {
          html += '<div style="text-align:center;padding:16px;margin-bottom:16px;background:#0a0a0a;border:1px solid #1e1e1e;">'
            + '<div style="color:#555;font-size:9px;letter-spacing:3px;margin-bottom:4px;">TOTAL DISCLOSED DONATIONS</div>'
            + '<div style="color:#c8001a;font-size:32px;font-weight:900;letter-spacing:-1px;">' + formatAmount(totalCents) + '</div>'
            + '</div>';
        }

        if (isParty) {
          html += '<div style="background:#111;border:1px solid #1e1e1e;padding:10px 12px;margin-bottom:12px;">'
            + '<div style="color:#ff8c00;font-size:11px;font-weight:900;letter-spacing:1px;margin-bottom:4px;">⚠ PARTY DISCLOSURES</div>'
            + '<div style="color:#888;font-size:11px;line-height:1.5;">Donations to <strong style="color:#ccc;">' + esc(p.partyName || p.party || 'their party') + '</strong> — individual MP disclosures not required for party members.</div>'
            + '</div>';
        }

        // Sort by amount DESC, group by year DESC
        var sorted = allDonations.slice().sort(function(a, b) { return (b.amountCents || 0) - (a.amountCents || 0); });
        var years = {};
        sorted.forEach(function(d) {
          var yr = d.year ? String(d.year) : 'YEAR UNKNOWN';
          if (!years[yr]) years[yr] = [];
          years[yr].push(d);
        });
        var yearKeys = Object.keys(years).sort(function(a, b) {
          if (a === 'YEAR UNKNOWN') return 1;
          if (b === 'YEAR UNKNOWN') return -1;
          return Number(b) - Number(a);
        });

        var LIMIT = 10;
        yearKeys.forEach(function(yr) {
          var items = years[yr];
          var sectionId = 'donors-yr-' + yr.replace(/[^a-z0-9]/gi, '').toLowerCase();
          var hiddenClass = sectionId + '-hidden';
          var toggleId = sectionId + '-toggle';
          html += '<div style="margin-bottom:20px;">'
            + '<div style="color:#555;font-size:9px;letter-spacing:3px;margin-bottom:8px;padding-bottom:4px;border-bottom:1px solid #1a1a1a;">'
              + esc(yr) + ' (' + items.length + ')'
            + '</div>';
          items.forEach(function(d, i) {
            var hidden = i >= LIMIT;
            var classAttr = hidden ? ' class="' + hiddenClass + '" data-display="flex"' : '';
            html += '<div' + classAttr + ' style="' + (hidden ? 'display:none;' : 'display:flex;') + 'justify-content:space-between;align-items:center;padding:10px;background:#0d0d0d;border:1px solid #1a1a1a;margin-bottom:8px;">'
              + '<div style="display:flex;gap:10px;align-items:center;">'
              + '<span style="font-size:14px;">' + donorFlag(d.amountCents) + '</span>'
              + '<div><div style="color:#ccc;font-size:12px;">' + esc(d.donorName) + '</div>'
              + (d.notes ? '<div style="color:#555;font-size:10px;">' + esc(d.notes) + '</div>' : '')
              + '</div></div>'
              + '<div style="color:#c8001a;font-size:14px;font-weight:900;">' + formatAmount(d.amountCents) + '</div>'
              + '</div>';
          });
          if (items.length > LIMIT) html += showMoreBtn(toggleId, hiddenClass, 'SHOW MORE (' + (items.length - LIMIT) + ' more)');
          html += '</div>';
        });

        html += '<div style="color:#333;font-size:10px;margin-top:4px;">Source: Australian Electoral Commission — '
          + (isParty ? 'Party Annual Returns' : 'Transparency Register')
          + ' transparency.aec.gov.au</div>';
        return html;
      }

      // ── Typewriter helpers ──────────────────────────────────────────────────

      function typeInto(el, text, speed, soundFn) {
        speed = speed || 45;
        soundFn = soundFn || function() {};
        return new Promise(function(resolve) {
          el.textContent = '';
          var cursor = document.createElement('span');
          cursor.className = 'type-field-cursor';
          el.appendChild(cursor);
          var i = 0;
          function tick() {
            if (i >= text.length) {
              cursor.classList.add('done');
              resolve();
              return;
            }
            var tn = document.createTextNode(text[i]);
            el.insertBefore(tn, cursor);
            if (text[i] !== ' ') soundFn();
            i++;
            setTimeout(tick, speed + (Math.random() * 18 - 9));
          }
          setTimeout(tick, 80);
        });
      }

      // ── Tab switching + AI lazy load ────────────────────────────────────────

      var tabNames = ['actions', 'donors', 'promises', 'foreign', 'policy'];
      var aiLoaded = {};

      function switchTab(activeTab) {
        tabNames.forEach(function(t) {
          var btn = document.getElementById('tab-btn-' + t);
          var panel = document.getElementById('panel-' + t);
          if (t === activeTab) {
            btn.style.background = '#111';
            btn.style.borderBottomColor = '#c8001a';
            btn.style.color = '#f0f0f0';
            panel.style.display = 'block';
            if ((t === 'policy' || t === 'actions') && !aiLoaded[t]) {
              aiLoaded[t] = true;
              loadAiSummary(t);
            }
          } else {
            btn.style.background = 'transparent';
            btn.style.borderBottomColor = 'transparent';
            btn.style.color = '#444';
            panel.style.display = 'none';
          }
        });
      }

      function loadAiSummary(tabName) {
        var endpoint = tabName === 'policy'
          ? '/api/v1/politicians/' + politicianId + '/policy-summary'
          : '/api/v1/politicians/' + politicianId + '/actions-summary';
        var el = document.getElementById('ai-summary-' + tabName);
        var card = document.getElementById('ai-card-' + tabName);
        if (!el) return;
        fetch(endpoint)
          .then(function(r) { return r.json(); })
          .then(function(data) {
            var text = tabName === 'policy' ? data.summary : data.blurb;
            if (text) {
              el.classList.remove('ai-loading');
              el.style.color = '#999';
              el.style.fontStyle = 'normal';
              el.textContent = text;
            } else if (card) {
              card.style.display = 'none';
            }
          })
          .catch(function() { if (card) card.style.display = 'none'; });
      }

      // ── Load profile ────────────────────────────────────────────────────────

      async function loadProfile() {
        var card = document.getElementById('mugshot-card');
        try {
          var res = await fetch('/api/v1/politicians/' + politicianId + '.json');
          var policyRes = await fetch('/api/v1/politicians/' + politicianId + '/policy-scores.json');
          if (res.status === 404) {
            card.innerHTML = '<div style="text-align:center;padding:60px;color:#333;font-size:12px;">Politician not found.</div>';
            return;
          }
          var data = await res.json();
          var policyData = policyRes.ok ? await policyRes.json() : { policyScores: [] };
          var p = data.politician;
          var actions = data.actions || [];
          var donations = data.donations || [];
          var promises = data.promises || [];
          var foreignTies = data.foreignTies || [];
          var policyScores = policyData.policyScores || [];
          var partyDonations = data.partyDonations || [];

          var caseNum = 'AF-' + (p.id || '').replace(/[^0-9]/g, '').slice(0, 6);
          var chamberLabel = p.chamber === 'senate' ? 'Senator' : 'Member of Parliament';
          var brokenCount = promises.filter(function(pr) { return pr.status === 'broken'; }).length;

          var photoImgHtml = p.photoUrl
            ? '<img src="' + esc(p.photoUrl) + '" alt="' + esc(p.name) + '" style="width:100%;height:100%;object-fit:cover;object-position:top;filter:grayscale(85%) contrast(1.4) brightness(0.75) sepia(20%);display:block;" onerror="this.style.display=\'none\';this.nextElementSibling.style.display=\'flex\'">'
            : '';
          var noPhotoDisplay = p.photoUrl ? 'none' : 'flex';

          var actionsHtml = buildActionsHtml(actions);
          var donationsHtml = buildDonationsHtml(donations, partyDonations, p);

          // Promises HTML
          var promisesHtml = '';
          if (promises.length === 0) {
            promisesHtml = '<div style="color:#333;font-size:12px;text-align:center;padding:40px 0;">No election promises on record.</div>';
          } else {
            promises.forEach(function(pr) {
              var st = pr.status || 'pending';
              var icon = st === 'kept' ? '✓ KEPT' : st === 'broken' ? '✗ BROKEN' : st === 'partial' ? '~ PARTIAL' : '? PENDING';
              promisesHtml += '<div style="padding:12px;background:#0d0d0d;border:1px solid #1a1a1a;border-left:3px solid ' + promiseBorderColor(st) + ';margin-bottom:10px;">'
                + '<div style="color:#888;font-size:12px;font-style:italic;margin-bottom:6px;">"' + esc(pr.title) + '"</div>'
                + '<div style="display:flex;gap:8px;align-items:flex-start;">'
                + '<span style="font-size:10px;font-weight:900;letter-spacing:1px;min-width:60px;color:' + promiseStatusColor(st) + ';">' + icon + '</span>'
                + '<span style="color:#aaa;font-size:12px;">' + esc(pr.description || pr.notes || '') + '</span>'
                + '</div>'
                + '<div style="margin-top:6px;">'
                + (pr.madeDate ? '<span style="font-size:10px;color:#555;margin-right:8px;">Made: ' + formatDate(pr.madeDate) + '</span>' : '')
                + (pr.sourceUrl ? '<a href="' + esc(pr.sourceUrl) + '" target="_blank" rel="noopener" style="font-size:10px;color:#4499ff;margin-right:8px;text-decoration:none;">Source ↗</a>' : '')
                + (pr.evidenceUrl ? '<a href="' + esc(pr.evidenceUrl) + '" target="_blank" rel="noopener" style="font-size:10px;color:#4499ff;margin-right:8px;text-decoration:none;">Evidence ↗</a>' : '')
                + '</div></div>';
            });
          }

          // Foreign ties HTML
          var foreignHtml = '';
          if (foreignTies.length === 0) {
            foreignHtml = '<div style="color:#333;font-size:12px;text-align:center;padding:40px 0;">No foreign ties on record.</div>';
          } else {
            foreignTies.forEach(function(f) {
              foreignHtml += '<div style="display:flex;justify-content:space-between;align-items:center;padding:10px;background:#0d0d0d;border:1px solid #1a1a1a;margin-bottom:8px;">'
                + '<div><div style="color:#ccc;font-size:12px;margin-bottom:3px;">' + esc(f.entityName) + (f.entityCountry ? ' (' + esc(f.entityCountry) + ')' : '') + '</div>'
                + '<div style="color:#555;font-size:11px;">' + esc(f.relationshipType || f.description || '') + '</div></div>'
                + '<span style="' + riskBadgeStyle(f.riskRating) + '">' + (f.riskRating || 'LOW').toUpperCase() + '</span>'
                + '</div>';
            });
          }

          var policyHtml = buildPolicyHtml(policyScores);

          var tabBtnBase = 'flex:1;padding:10px 4px;border:none;font-size:9px;font-weight:900;letter-spacing:1px;cursor:pointer;font-family:\'Courier New\',monospace;border-bottom:2px solid transparent;';

          card.innerHTML =
            '<div style="background:#c8001a;padding:8px 16px;display:flex;justify-content:space-between;align-items:center;">'
              + '<span style="color:#fff;font-size:11px;font-weight:900;letter-spacing:3px;">ON THE RECORD — PUBLIC RECORD</span>'
              + '<span style="color:rgba(255,255,255,0.7);font-size:10px;letter-spacing:1px;">CASE #' + esc(caseNum) + '</span>'
            + '</div>'
            + '<div style="display:flex;border-bottom:1px solid #1e1e1e;">'
              + '<div style="position:relative;width:200px;min-width:200px;background:#111;overflow:hidden;">'
                + '<div style="position:absolute;right:0;top:0;bottom:0;width:28px;background:#0a0a0a;border-left:1px solid #222;display:flex;flex-direction:column;justify-content:space-between;padding:8px 0;z-index:2;">'
                  + '<span style="color:#444;font-size:7px;text-align:center;border-bottom:1px solid #1a1a1a;padding-bottom:2px;">6\'2"</span>'
                  + '<span style="color:#444;font-size:7px;text-align:center;border-bottom:1px solid #1a1a1a;padding-bottom:2px;">6\'0"</span>'
                  + '<span style="color:#444;font-size:7px;text-align:center;border-bottom:1px solid #1a1a1a;padding-bottom:2px;">5\'10"</span>'
                  + '<span style="color:#444;font-size:7px;text-align:center;border-bottom:1px solid #1a1a1a;padding-bottom:2px;">5\'8"</span>'
                  + '<span style="color:#444;font-size:7px;text-align:center;border-bottom:1px solid #1a1a1a;padding-bottom:2px;">5\'6"</span>'
                + '</div>'
                + '<div style="width:172px;height:220px;overflow:hidden;position:relative;background:#1a1a1a;">'
                  + photoImgHtml
                  + '<div style="width:100%;height:100%;display:' + noPhotoDisplay + ';align-items:center;justify-content:center;color:#333;font-size:11px;text-align:center;padding:10px;">PHOTO<br>UNAVAILABLE</div>'
                  + '<div style="position:absolute;inset:0;background:radial-gradient(ellipse at center,transparent 40%,rgba(0,0,0,0.7) 100%);pointer-events:none;"></div>'
                  + '<div style="position:absolute;inset:0;background-image:repeating-linear-gradient(0deg,transparent,transparent 2px,rgba(0,0,0,0.08) 2px,rgba(0,0,0,0.08) 4px);pointer-events:none;"></div>'
                + '</div>'
                + '<div style="background:#0a0a0a;border-top:1px solid #1e1e1e;padding:8px;text-align:center;">'
                  + '<div style="color:#c8001a;font-size:10px;letter-spacing:2px;margin-bottom:3px;">DAYS IN OFFICE</div>'
                  + '<div id="days-in-office-val" style="color:#666;font-size:11px;">—</div>'
                + '</div>'
              + '</div>'
              + '<div style="flex:1;padding:20px;border-left:1px solid #1a1a1a;display:flex;flex-direction:column;gap:12px;">'
                + '<div>'
                  + '<div style="color:#444;font-size:10px;letter-spacing:3px;margin-bottom:4px;">FULL NAME</div>'
                  + '<div id="profile-name-val" style="color:#f0f0f0;font-size:22px;font-weight:900;line-height:1.1;letter-spacing:-0.5px;">' + esc(p.name).toUpperCase() + '</div>'
                + '</div>'
                + '<div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">'
                  + '<div><div style="color:#444;font-size:9px;letter-spacing:2px;margin-bottom:3px;">OFFICE</div><div style="color:#aaa;font-size:12px;">' + esc(chamberLabel) + '</div></div>'
                  + '<div><div style="color:#444;font-size:9px;letter-spacing:2px;margin-bottom:3px;">PARTY</div><div style="color:#aaa;font-size:12px;">' + esc(p.partyName || p.party || 'Unknown') + '</div></div>'
                  + '<div><div style="color:#444;font-size:9px;letter-spacing:2px;margin-bottom:3px;">ELECTORATE</div><div style="color:#aaa;font-size:12px;">' + esc(p.electorate || 'N/A') + '</div></div>'
                  + '<div><div style="color:#444;font-size:9px;letter-spacing:2px;margin-bottom:3px;">STATUS</div><div style="color:#c8001a;font-weight:900;letter-spacing:2px;font-size:12px;">IN POWER</div></div>'
                + '</div>'
                + '<div style="display:flex;gap:8px;flex-wrap:wrap;margin-top:4px;">'
                  + '<div style="background:#111;border:1px solid #1e1e1e;border-radius:2px;padding:4px 10px;text-align:center;"><div style="color:#c8001a;font-size:16px;font-weight:900;">' + actions.length + '</div><div style="color:#444;font-size:8px;letter-spacing:1px;">ACTIONS</div></div>'
                  + '<div style="background:#111;border:1px solid #1e1e1e;border-radius:2px;padding:4px 10px;text-align:center;"><div style="color:#c8001a;font-size:16px;font-weight:900;">' + (donations.length || partyDonations.length) + '</div><div style="color:#444;font-size:8px;letter-spacing:1px;">DONORS</div></div>'
                  + '<div style="background:#111;border:1px solid #1e1e1e;border-radius:2px;padding:4px 10px;text-align:center;"><div style="color:#c8001a;font-size:16px;font-weight:900;">' + brokenCount + '</div><div style="color:#444;font-size:8px;letter-spacing:1px;">BROKEN PROMISES</div></div>'
                  + '<div style="background:#111;border:1px solid #1e1e1e;border-radius:2px;padding:4px 10px;text-align:center;"><div style="color:#c8001a;font-size:16px;font-weight:900;">' + foreignTies.length + '</div><div style="color:#444;font-size:8px;letter-spacing:1px;">FOREIGN LINKS</div></div>'
                + '</div>'
              + '</div>'
            + '</div>'
            + '<div style="display:flex;border-bottom:1px solid #1a1a1a;background:#080808;">'
              + '<button id="tab-btn-actions" style="' + tabBtnBase + 'background:#111;border-bottom-color:#c8001a;color:#f0f0f0;">ACTIONS</button>'
              + '<button id="tab-btn-donors" style="' + tabBtnBase + 'background:transparent;color:#444;">FOLLOW THE MONEY</button>'
              + '<button id="tab-btn-promises" style="' + tabBtnBase + 'background:transparent;color:#444;">THEY PROMISED</button>'
              + '<button id="tab-btn-foreign" style="' + tabBtnBase + 'background:transparent;color:#444;">FOREIGN TIES</button>'
              + '<button id="tab-btn-policy" style="' + tabBtnBase + 'background:transparent;color:#444;">POLICY</button>'
            + '</div>'
            + '<div id="panel-actions" style="display:block;padding:16px;min-height:200px;">'
              + '<div style="color:#444;font-size:9px;letter-spacing:2px;margin-bottom:12px;">DOCUMENTED ACTIONS AGAINST THE NATIONAL INTEREST</div>'
              + actionsHtml
            + '</div>'
            + '<div id="panel-donors" style="display:none;padding:16px;min-height:200px;">'
              + donationsHtml
            + '</div>'
            + '<div id="panel-promises" style="display:none;padding:16px;min-height:200px;">'
              + '<div style="color:#444;font-size:9px;letter-spacing:2px;margin-bottom:8px;">WHAT THEY SAID VS WHAT THEY DID</div>'
              + promisesHtml
            + '</div>'
            + '<div id="panel-foreign" style="display:none;padding:16px;min-height:200px;">'
              + '<div style="color:#444;font-size:9px;letter-spacing:2px;margin-bottom:8px;">FOREIGN ENTITY ASSOCIATIONS & RISK ASSESSMENT</div>'
              + foreignHtml
            + '</div>'
            + '<div id="panel-policy" style="display:none;padding:16px;min-height:200px;">'
              + '<div style="color:#444;font-size:9px;letter-spacing:2px;margin-bottom:12px;">HOW THEY VOTE ON POLICIES — SOURCE: THEY VOTE FOR YOU</div>'
              + policyHtml
            + '</div>'
            + '<div style="border-top:1px solid #1a1a1a;padding:10px 16px;display:flex;justify-content:space-between;align-items:center;background:#080808;">'
              + '<span style="color:#2a2a2a;font-size:10px;letter-spacing:1px;">ALL DATA SOURCED FROM PUBLIC RECORDS</span>'
              + '<span style="color:#c8001a;font-size:10px;letter-spacing:2px;font-weight:900;">ONTHERECORD.FYI</span>'
            + '</div>';

          tabNames.forEach(function(t) {
            document.getElementById('tab-btn-' + t).addEventListener('click', function() { switchTab(t); });
          });

          // ── Typewriter reveals ──────────────────────────────────────────────
          var nameEl = document.getElementById('profile-name-val');
          var nameSoundFn = function() { if (window.__sounds && window.__sounds.playTypeTickName) window.__sounds.playTypeTickName(); };
          var daysSoundFn = function() { if (window.__sounds && window.__sounds.playTypeTickDays) window.__sounds.playTypeTickDays(); };
          if (nameEl) typeInto(nameEl, (p.name || '').toUpperCase(), 55, nameSoundFn);

          var daysEl = document.getElementById('days-in-office-val');
          if (daysEl) {
            var daysText;
            if (p.termStart) {
              var start = new Date(p.termStart);
              var now = new Date();
              var days = Math.floor((now.getTime() - start.getTime()) / 86400000);
              daysText = days.toLocaleString() + ' days';
            } else {
              daysText = p.jurisdiction || 'Unknown';
            }
            typeInto(daysEl, daysText, 60, daysSoundFn);
          }

          // Load AI summary for the default (actions) tab immediately
          aiLoaded['actions'] = true;
          loadAiSummary('actions');

          document.title = p.name.toUpperCase() + ' | On The Record';

        } catch (e) {
          card.innerHTML = '<div style="text-align:center;padding:60px;color:#333;font-size:12px;">Failed to load profile.</div>';
        }
      }

      loadProfile();
    </script>
  </body>
</html>
