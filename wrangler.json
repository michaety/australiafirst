{
  "name": "australiafirst",
  "compatibility_date": "2025-10-08",
  "compatibility_flags": ["nodejs_compat"],
  "main": "./dist/worker-wrapper.js",
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS"
  },
  "observability": {
    "enabled": true
  },
  "upload_source_maps": true,
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "australiafirst",
      "database_id": "f9e743c7-e125-4d30-a75c-60d4c5fe52eb",
      "preview_database_id": "f9e743c7-e125-4d30-a75c-60d4c5fe52eb"
    }
  ],
  "kv_namespaces": [
    {
      "binding": "KV",
      "id": "f8163c67a46d4e41a0a58b114180966a",
      "preview_id": "8f63074a77ca4eeebdec648f48c42625"
    },
    {
      "binding": "SESSION",
      "id": "f8163c67a46d4e41a0a58b114180966a",
      "preview_id": "8f63074a77ca4eeebdec648f48c42625"
    }
  ],
  "r2_buckets": [
    {
      "binding": "R2",
      "bucket_name": "australiafirst",
      "preview_bucket_name": "australiafirst"
    }
  ],
  "ai": {
    "binding": "AI"
  },
  "routes": [
    { "pattern": "ontherecord.fyi/*", "zone_name": "ontherecord.fyi" },
    { "pattern": "www.ontherecord.fyi/*", "zone_name": "ontherecord.fyi" },
    { "pattern": "ndis.ontherecord.fyi/*", "zone_name": "ontherecord.fyi" }
  ],
  "triggers": {
    "crons": [
      "0 2 * * *",
      "30 2 * * *",
      "0 3 * * *",
      "30 3 * * *",
      "0 4 * * *",
      "0 5 * * *",
      "30 5 * * *",
      "0 6 * * *"
    ]
  }
}
